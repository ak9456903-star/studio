
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user of Nullpk AI Content Studio.",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "pro"] },
        "credits": { "type": "number" },
        "total_videos_created": { "type": "number" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email"]
    },
    "VideoRequest": {
      "title": "VideoRequest",
      "type": "object",
      "description": "Represents a complete video creation request.",
      "properties": {
        "requestId": { "type": "string" },
        "user_id": { "type": "string" },
        "topic": { "type": "string" },
        "style": { "type": "string" },
        "tone": { "type": "string" },
        "duration": { "type": "string" },
        "language": { "type": "string" },
        "research_summary": { "type": "string" },
        "script": { "type": "string" },
        "voice_url": { "type": "string" },
        "video_url": { "type": "string" },
        "thumbnail_url": { "type": "string" },
        "subtitles_url": { "type": "string" },
        "seo_title": { "type": "string" },
        "seo_description": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "hashtags": { "type": "array", "items": { "type": "string" } },
        "youtube_url": { "type": "string" },
        "viral_score": { "type": "number" },
        "status": { "type": "string", "enum": ["processing", "completed", "failed"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "topic", "status"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and credit data."
    },
    "/video_requests/{requestId}": {
      "schema": "VideoRequest",
      "description": "Complete history of video generation requests."
    }
  }
}
