{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Desi Content Creator application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user (matches auth.uid)."
        },
        "name": {
          "type": "string",
          "description": "User's display name."
        },
        "email": {
          "type": "string",
          "description": "User's email address.",
          "format": "email"
        },
        "photo": {
          "type": "string",
          "description": "URL of the user's profile photo.",
          "format": "uri"
        },
        "language": {
          "type": "string",
          "description": "User's preferred language (Hinglish, Hindi, or English)."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the user account was created.",
          "format": "date-time"
        },
        "lastActive": {
          "type": "string",
          "description": "Timestamp of the user's last activity.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "createdAt"
      ]
    },
    "Chat": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Chat",
      "type": "object",
      "description": "Represents a single chat session.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the chat session."
        },
        "userId": {
          "type": "string",
          "description": "The user who initiated the chat."
        },
        "title": {
          "type": "string",
          "description": "A title for the chat session, generated by the AI."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the chat was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp when the chat was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "title",
        "createdAt",
        "updatedAt"
      ]
    },
    "ChatMessage": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ChatMessage",
      "type": "object",
      "description": "Represents a single message within a chat session.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the chat message."
        },
        "chatId": {
          "type": "string",
          "description": "The chat session this message belongs to."
        },
        "role": {
          "type": "string",
          "description": "Who sent the message.",
          "enum": ["user", "ai"]
        },
        "text": {
          "type": "string",
          "description": "The text content of the message."
        },
        "imageUrl": {
            "type": "string",
            "description": "URL of an image in the message (optional).",
            "format": "uri"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the message was sent.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "chatId",
        "role",
        "text",
        "createdAt"
      ]
    },
    "ImageGeneration": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ImageGeneration",
      "type": "object",
      "description": "Represents an image generated by the AI.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the generated image."
        },
        "userId": {
          "type": "string",
          "description": "The user who generated the image."
        },
        "prompt": {
          "type": "string",
          "description": "The text prompt used to generate the image."
        },
        "imageUrl": {
          "type": "string",
          "description": "URL of the generated image.",
          "format": "uri"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the image was generated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "prompt",
        "imageUrl",
        "createdAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "schema": {
            "$ref": "#/entities/User"
          },
          "description": "Stores user profile information."
        }
      },
      {
        "path": "/users/{userId}/chats/{chatId}",
        "definition": {
          "schema": {
            "$ref": "#/entities/Chat"
          },
          "description": "Stores chat sessions for each user."
        }
      },
      {
        "path": "/users/{userId}/chats/{chatId}/messages/{messageId}",
        "definition": {
          "schema": {
            "$ref": "#/entities/ChatMessage"
          },
          "description": "Stores individual chat messages within a chat session."
        }
      },
      {
        "path": "/users/{userId}/images/{imageId}",
        "definition": {
          "schema": {
            "$ref": "#/entities/ImageGeneration"
          },
          "description": "Stores images generated by the user."
        }
      }
    ]
  }
}
