/**
 * Nullpk AI Studio Security Rules
 * Enforces user-ownership for videos and profiles.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Check if the authenticated user owns the document (by ID or data field)
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User profiles: Only the owner can manage their data
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Video requests: Owners can create and list their own projects
    match /video_requests/{requestId} {
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      
      // Allow read/update/delete/list if the document belongs to the user
      // For list queries, this requires the query to filter by user_id
      allow read, update, delete, list: if isSignedIn() && (
        resource == null || resource.data.user_id == request.auth.uid
      );
    }

    // History/Activity logs: Private to the user
    match /history/{id} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, list: if isSignedIn() && (
        resource == null || resource.data.userId == request.auth.uid
      );
    }
  }
}