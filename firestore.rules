/**
 * Nullpk AI Studio Security Rules
 * Enforces user-ownership for videos and profiles.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Check if the authenticated user owns the document (by UID)
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User profiles: Only the owner can manage their data
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Video requests: Owners can create and read their own projects
    match /video_requests/{requestId} {
      // Allow creation if the user is signed in and provides their own UID
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      
      // Allow read (get/list), update, and delete if the document belongs to the user
      // For list queries, the rule is enforced by checking if the query filters by user_id
      allow read, update, delete: if isSignedIn() && (
        resource == null || resource.data.user_id == request.auth.uid
      );
    }

    // History/Activity logs: Private to the user
    match /history/{id} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (
        resource == null || resource.data.userId == request.auth.uid
      );
    }
  }
}