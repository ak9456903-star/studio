/**
 * This ruleset enforces a user-ownership model for a content creation application.
 * Updated to support Nullpk AI Studio blueprint collections.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------
    
    match /users/{userId} {
      allow read, delete: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow list: if false; 
    }
    
    match /video_requests/{requestId} {
      // Users can only create and manage their own video requests
      allow create: if isOwner(request.resource.data.user_id);
      allow read, update, delete: if isOwner(resource.data.user_id);
      
      // Allow list queries that filter by current user's ID
      allow list: if isSignedIn();
    }
    
    match /history/{historyId} {
      // Legacy support for chat history or other analytics
      allow create: if isOwner(request.resource.data.userId);
      allow read, update, delete: if isOwner(resource.data.userId);
      allow list: if isSignedIn();
    }
  }
}