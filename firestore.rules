/**
 * This ruleset enforces a strict user-ownership model for a ChatGPT-style application.
 *
 * Core Philosophy:
 * The security model is centered around the principle that users can only access their own
 * data. All user-generated content, including chat sessions and generated images, is
 * strictly segregated and accessible only by the authenticated owner.
 *
 * Data Structure:
 * All user-specific data is nested hierarchically under the `/users/{userId}` path.
 * This structure includes subcollections for `images`,
 * ensuring that data access can be controlled simply by verifying ownership at the top
 * of the path. This design inherently secures queries and prevents data leakage.
 *
 * Key Security Decisions:
 * - User Enumeration Blocked: Listing documents in the top-level `/users` collection is
 *   explicitly disallowed to protect user privacy.
 * - Strict Ownership: All read and write operations on user content require the request's
 *   authentication UID to match the `{userId}` in the document path.
 * - Relational Integrity: On creation, documents must contain an ownership field (e.g., `userId`)
 *   that matches the user ID in the path. This field is enforced as immutable on updates,
 *   preventing documents from being reassigned to other users.
 *
 * Denormalization for Authorization:
 * This ruleset relies on the path structure itself (`/users/{userId}/...`) as the primary
 * mechanism for authorization. Additionally, documents in subcollections (like `images`) are 
 * expected to contain a denormalized `userId` field. This allows for
 * simple, fast, and secure validation rules without requiring expensive `get()` calls to
 * parent documents.
 *
 * Structural Segregation:
 * The data model effectively segregates different types of user data into distinct
 * subcollections (`/images`). This creates clear boundaries and allows for
 * granular, path-based security rules that are easy to understand and maintain.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user is the owner of the resource.
     * @param userId The UID of the user to check against.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the user is the owner and the document already exists.
     * Essential for secure update and delete operations.
     * @param userId The UID of the user to check against.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && exists(/databases/$(database)/documents/users/$(userId));
    }

    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------
    
    match /users/{userId} {
      allow read, delete: if isOwner(userId);
      allow create: if request.auth.uid == userId && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow list: if false; // Prevent user enumeration
    }
    
    match /users/{userId}/images/{imageId} {
      allow read, write, delete: if isOwner(userId);
    }
  }
}
